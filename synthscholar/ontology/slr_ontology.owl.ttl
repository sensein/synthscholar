        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:pico_intervention ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:research_question ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:registry ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:registration_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:IncludedSource ;
            owl:onProperty slr:included_sources ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:PrimaryFocusEnum ;
            owl:onProperty slr:primary_focus ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:date_of_last_search ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty slr:total_included ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:total_identified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:synthesis_narrative ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:synthesis_narrative ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:excluded_sources ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:date_of_last_search ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:total_included ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:research_question ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:included_sources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:competing_interests ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:pico_intervention ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:eligibility_framework ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:artifact_store ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:primary_focus ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:pico_outcome ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ReportingStandardEnum ;
            owl:onProperty slr:reporting_standard ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:funding ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:registration_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:limitations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty slr:date_of_last_search ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:pico_intervention ],
        slr:ProvenanceMixin ;
    skos:definition "The top-level container for a complete systematic literature review." ;
    skos:exactMatch prov:Activity ;
    skos:inScheme slr: .

slr:AppraisalItem a owl:Class ;
    rdfs:label "AppraisalItem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slr:ItemRatingEnum ;
            owl:onProperty slr:rating ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:justification ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:justification ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:item_text ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:item_text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:rating ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:justification ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:rating ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:item_text ] ;
    skos:definition "An individual item in a structured quality appraisal checklist." ;
    skos:inScheme slr: .

slr:ArtifactStore a owl:Class ;
    rdfs:label "ArtifactStore" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:store_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:store_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:StoredArtifact ;
            owl:onProperty slr:artifacts ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:artifacts ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:store_id ] ;
    skos:definition "A collection of content-addressed stored artifacts." ;
    skos:inScheme slr: .

slr:BiasTransparencyDomain a owl:Class ;
    rdfs:label "BiasTransparencyDomain" ;
    rdfs:subClassOf slr:AppraisalDomain ;
    skos:definition "Appraisal domain covering bias, transparency, and reporting quality." ;
    skos:inScheme slr: .

slr:ChartingActivity a owl:Class ;
    rdfs:label "ChartingActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slr:ReviewEvent ;
            owl:onProperty slr:review_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:tool_invocations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:review_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:model_invocations ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ToolInvocation ;
            owl:onProperty slr:tool_invocations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:user_inputs ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:UserInput ;
            owl:onProperty slr:user_inputs ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ModelInvocation ;
            owl:onProperty slr:model_invocations ],
        slr:Activity ;
    skos:definition "A data charting or extraction activity for included sources." ;
    skos:inScheme slr: .

slr:ComparisonGroup a owl:Class ;
    rdfs:label "ComparisonGroup" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:comparator_notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:comparator_notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:comparator_description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:comparator_notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:comparator_sample_size ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty slr:comparator_sample_size ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:comparator_sample_size ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:comparator_description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:comparator_description ] ;
    skos:definition "Section D — comparison or control group details." ;
    skos:inScheme slr: .

slr:DataCollection a owl:Class ;
    rdfs:label "DataCollection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slr:FeatureTypeEnum ;
            owl:onProperty slr:feature_types ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:ground_truth_method ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:DataTypeEnum ;
            owl:onProperty slr:data_types ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:data_quality_notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:data_quality_notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:feature_types ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:missing_data_handling ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:ground_truth_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:missing_data_handling ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:data_types ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:ground_truth_method ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:missing_data_handling ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:data_quality_notes ] ;
    skos:definition "Section E — data collection and features." ;
    skos:inScheme slr: .

slr:DataCollectionDomain a owl:Class ;
    rdfs:label "DataCollectionDomain" ;
    rdfs:subClassOf slr:AppraisalDomain ;
    skos:definition "Appraisal domain covering data collection methods and measurement." ;
    skos:inScheme slr: .

slr:ExcludedSource a owl:Class ;
    rdfs:label "ExcludedSource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slr:ExclusionReasonEnum ;
            owl:onProperty slr:exclusion_reason ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:exclusion_notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:exclusion_notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ScreeningStageEnum ;
            owl:onProperty slr:exclusion_stage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:exclusion_reason ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:exclusion_stage ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:exclusion_reason ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:exclusion_notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:exclusion_stage ],
        slr:Source ;
    skos:definition "A source screened and excluded from the review." ;
    skos:inScheme slr: .

slr:IncludedSource a owl:Class ;
    rdfs:label "IncludedSource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:appraisal_history ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:was_derived_from ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:CriticalAppraisal ;
            owl:onProperty slr:critical_appraisal ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:charting_record_history ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:was_derived_from ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:RiskOfBiasAssessment ;
            owl:onProperty slr:risk_of_bias ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ChartingRecord ;
            owl:onProperty slr:charting_record ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:critical_appraisal ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ChartingRecord ;
            owl:onProperty slr:charting_record_history ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:was_derived_from ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:risk_of_bias ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:charting_record ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:critical_appraisal ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:CriticalAppraisal ;
            owl:onProperty slr:appraisal_history ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:risk_of_bias ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:charting_record ],
        slr:Source ;
    skos:definition "A source that meets eligibility criteria and is included in the review." ;
    skos:inScheme slr: .

slr:MethodsAnalysisDomain a owl:Class ;
    rdfs:label "MethodsAnalysisDomain" ;
    rdfs:subClassOf slr:AppraisalDomain ;
    skos:definition "Appraisal domain covering analytical methods and statistical rigour." ;
    skos:inScheme slr: .

slr:MethodsAndResults a owl:Class ;
    rdfs:label "MethodsAndResults" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:confidence_interval ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:key_results ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:algorithm_names ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:flags ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:direction_of_effect ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:validation_methodology ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:outcome ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:algorithm_names ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:MethodCategoryEnum ;
            owl:onProperty slr:method_category ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:EffectMeasureEnum ;
            owl:onProperty slr:effect_measure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:primary_metric ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:primary_metric_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:outcome ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:FlagTypeEnum ;
            owl:onProperty slr:flags ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:PerformanceMetricEnum ;
            owl:onProperty slr:primary_metric ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:DirectionOfEffectEnum ;
            owl:onProperty slr:direction_of_effect ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:key_results ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:method_category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:p_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty slr:p_value ],
