slr:UserInput a owl:Class ;
    rdfs:label "UserInput" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:options_presented ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:influences ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:question_asked ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:UserInputTypeEnum ;
            owl:onProperty slr:input_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:captured_at_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:captured_at_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:input_value ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:input_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:input_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:ui_context ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:input_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:influences ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:options_presented ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:input_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:ui_context ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:question_asked ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty slr:captured_at_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:ui_context ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:input_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:question_asked ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:input_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:input_id ],
        slr:ProvenanceMixin ;
    skos:definition "A structured capture of input provided by a human user." ;
    skos:exactMatch prov:Entity ;
    skos:inScheme slr: .

