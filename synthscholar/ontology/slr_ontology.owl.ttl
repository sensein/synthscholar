slr:AppraisalDomain a owl:Class ;
    rdfs:label "AppraisalDomain" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slr:AppraisalItem ;
            owl:onProperty slr:items ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:items ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ConcernLevelEnum ;
            owl:onProperty slr:overall_concern ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:overall_concern ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:overall_concern ] ;
    skos:definition "Abstract base class for a domain within a structured quality appraisal." ;
    skos:inScheme slr: .

slr:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slr:ReviewerRoleEnum ;
            owl:onProperty slr:role ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:orcid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:affiliation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:orcid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:role ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:affiliation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:affiliation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:email ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:email ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:email ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:orcid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:role ],
        slr:Agent ;
    skos:definition "A human agent participating in the systematic review." ;
    skos:exactMatch prov:Person ;
    skos:inScheme slr: .

