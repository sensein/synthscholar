@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fabio: <http://purl.org/spar/fabio/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix slr: <https://w3id.org/slr-ontology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/slr-ontology/.owl.ttl> a owl:Ontology ;
    rdfs:label "slr-ontology" ;
    dcterms:title "Systematic Literature Review Ontology" ;
    pav:version "0.2.0" ;
    skos:definition "A LinkML schema for representing systematic literature reviews with full provenance. Covers PRISMA 2020 reporting, data charting (Sections A-G), four-domain critical appraisal, risk of bias assessment, and AI/LLM interaction provenance (prompts, model invocations, tool calls, user inputs, review events). Reuses PROV-O, Dublin Core, FaBiO, BIBO, schema.org, and SKOS." .

slr:AppraisalActivity a owl:Class ;
    rdfs:label "AppraisalActivity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:model_invocations ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ReviewEvent ;
            owl:onProperty slr:review_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:tool_invocations ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ToolInvocation ;
            owl:onProperty slr:tool_invocations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:review_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ModelInvocation ;
            owl:onProperty slr:model_invocations ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:UserInput ;
            owl:onProperty slr:user_inputs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:user_inputs ],
        slr:Activity ;
    skos:definition "A quality appraisal activity for included sources." ;
    skos:inScheme slr: .

slr:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:country ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:country ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:ror_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:ror_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:country ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:ror_id ],
        slr:Agent ;
    skos:definition "An institutional or corporate agent." ;
    skos:exactMatch prov:Organization ;
    skos:inScheme slr: .

slr:SystematicReview a owl:Class ;
    rdfs:label "SystematicReview" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:funding ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:pico_population ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ExcludedSource ;
            owl:onProperty slr:excluded_sources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:screening_activities ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:PreWorkflowSession ;
            owl:onProperty slr:pre_workflow_sessions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:funding ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:pico_outcome ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:pico_population ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:total_included ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:objective ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:EligibilityFrameworkEnum ;
            owl:onProperty slr:eligibility_framework ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:limitations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:competing_interests ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:eligibility_framework ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:registration_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:pico_comparison ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:limitations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:pico_comparison ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:registry ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:review_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:objective ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:pre_workflow_sessions ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:DatabaseEnum ;
            owl:onProperty slr:databases_searched ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:review_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:pico_comparison ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:competing_interests ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:synthesis_narrative ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:reporting_standard ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:total_identified ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:review_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ScreeningActivity ;
            owl:onProperty slr:screening_activities ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:objective ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ArtifactStore ;
            owl:onProperty slr:artifact_store ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:primary_focus ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:search_activities ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ProtocolRegistryEnum ;
            owl:onProperty slr:registry ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:artifact_store ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty slr:total_identified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:pico_population ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:SearchActivity ;
            owl:onProperty slr:search_activities ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:databases_searched ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
