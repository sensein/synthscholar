slr:ModelInvocation a owl:Class ;
    rdfs:label "ModelInvocation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:invocation_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:response_hash ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:response_uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:StopReasonEnum ;
            owl:onProperty slr:stop_reason ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:start_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:stop_reason ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty slr:total_tokens ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:SoftwareAgent ;
            owl:onProperty slr:performed_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty slr:output_tokens ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty slr:input_tokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:invocation_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:response_uri ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:cost_usd ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:on_behalf_of ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:response_text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:output_tokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:input_tokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:cost_usd ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:total_tokens ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:prompt ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty slr:cost_usd ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:on_behalf_of ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:start_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:output_tokens ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:invocation_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ModelConfiguration ;
            owl:onProperty slr:configuration ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-f0-9]{64}$" ] ) ] ;
            owl:onProperty slr:response_hash ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:configuration ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:Prompt ;
            owl:onProperty slr:prompt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:input_tokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:prompt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:response_text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:response_hash ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:performed_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty slr:start_time ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:configuration ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:end_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:response_uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:Agent ;
            owl:onProperty slr:on_behalf_of ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:performed_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:response_text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:end_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:total_tokens ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty slr:end_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:stop_reason ],
        slr:ProvenanceMixin ;
    skos:definition "A single invocation of a language model during the review workflow." ;
    skos:exactMatch prov:Activity ;
    skos:inScheme slr: .

