        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:original_values ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:reviewer_comment ],
        [ a owl:Restriction ;
