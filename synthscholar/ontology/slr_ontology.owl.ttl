slr:ProvenanceMixin a owl:Class ;
    rdfs:label "ProvenanceMixin" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:was_derived_from ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:was_generated_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:was_derived_from ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:was_derived_from ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:Agent ;
            owl:onProperty slr:was_attributed_to ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:generated_at_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:was_attributed_to ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:was_attributed_to ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:was_generated_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:generated_at_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty slr:generated_at_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:Activity ;
            owl:onProperty slr:was_generated_by ] ;
    skos:definition "Mixin providing PROV-O provenance slots to any class." ;
    skos:inScheme slr: .

