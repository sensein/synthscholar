slr:ToolInvocation a owl:Class ;
    rdfs:label "ToolInvocation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:tool_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:end_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:arguments_json ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:tool_invocation_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:arguments_json ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:result_uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:error_message ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:result_text ],
        [ a owl:Restriction ;
            owl:allValuesFrom slr:ToolCategoryEnum ;
            owl:onProperty slr:tool_category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:result_text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:arguments_json ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:tool_invocation_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:result_hash ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:parent_invocation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:start_time ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:result_hash ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:start_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:result_text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:success ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slr:error_message ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:error_message ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty slr:start_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:tool_category ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:success ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty slr:success ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:tool_invocation_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:string ;
                    owl:withRestrictions ( [ xsd:pattern "^[a-f0-9]{64}$" ] ) ] ;
            owl:onProperty slr:result_hash ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:parent_invocation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:tool_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:tool_category ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slr:result_uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty slr:result_uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty slr:end_time ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:end_time ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slr:tool_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slr:parent_invocation ],
        slr:ProvenanceMixin ;
    skos:definition "A single invocation of a tool during the review workflow." ;
    skos:exactMatch prov:Activity ;
    skos:inScheme slr: .

